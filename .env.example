# Copy to `.env` (or `.env.local` for overrides). Symfony loads:
# .env → .env.local → .env.$APP_ENV → .env.$APP_ENV.local
#
# Optional: copy APP_SECRET into a `.env` file in this directory for `docker compose`
# variable substitution (see docker-compose.yml).

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_generate_with_openssl_rand_hex_16
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=123456
DB_SERVER_VERSION=16
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?serverVersion=${DB_SERVER_VERSION}&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

WORKFLOW_MAIL_FROM=noreply@localhost
WORKFLOW_EMAIL_WEBHOOK_URL=http://localhost:5678/webhook/send-email
WORKFLOW_SMS_WEBHOOK_URL=http://localhost:5678/webhook/send-sms
WORKFLOW_SMS_DEFAULT_TO=

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###